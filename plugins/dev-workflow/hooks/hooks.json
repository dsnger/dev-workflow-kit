{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/codex-gate.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Bash|Skill|mcp__codex__.*)$",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/hooks/codex-gate.sh"
          }
        ]
      }
    ]
  }
}
